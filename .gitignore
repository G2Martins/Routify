# ========================================
# Routify — root .gitignore
# Cobre Python (BackEnd), Node/Expo (FrontEnd), IDE, OS, segredos.
# ========================================

# ---- Segredos e variáveis de ambiente ----
.env
.env.*
!.env.example
*.key
*secret*
*credentials*

# Chaves específicas do projeto
BackEnd/Servidor/config/.env
BackEnd/Servidor/config/tomtom_keys.json

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/

# ---- Modelos ML / artefatos pesados ----
BackEnd/Treinamento_IA/models/*.pkl
BackEnd/Treinamento_IA/models/*.parquet
BackEnd/Treinamento_IA/models/*.graphml
BackEnd/Treinamento_IA/models/mlruns/
mlruns/
*.h5
*.onnx

# Cache OSMnx
cache/
.osmnx_cache/

# ---- Node / Expo / React Native ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json.bak

# Expo
.expo/
.expo-shared/
dist/
web-build/
*.jks
*.p8
*.p12
*.mobileprovision
*.orig.*

# Metro
.metro-health-check*

# ---- TypeScript / JavaScript build ----
*.tsbuildinfo
.next/
out/

# ---- IDE / Editores ----
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.history/

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Logs / temporários ----
*.log
logs/
tmp/
temp/

# ---- Docs build ----
Docs/build/
*.pdf.bak

# ---- Claude / IA assistants ----
.claude/
